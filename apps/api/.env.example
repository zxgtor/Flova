# Copy to .env and adjust. Names match docs/foundation/architecture.md.

ENV=dev
API_ORIGIN=http://localhost:8000
WEB_ORIGIN=http://localhost:3000

AUTH_SECRET=change-me-32-bytes-or-more
AUTH_TOKEN_TTL_SECONDS=28800

# Dev: SQLite. Real: postgresql+asyncpg://flova:flova@localhost:5432/flova
DATABASE_URL=sqlite+aiosqlite:///./flova.db

REDIS_URL=redis://localhost:6379/0

STORAGE_BACKEND=local
STORAGE_LOCAL_ROOT=./storage

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

PIKPAK_USERNAME=
PIKPAK_PASSWORD=

GPU_BURST_API_KEY=
GPU_BURST_ENDPOINT=

# Video provider: "stub" (default) writes a placeholder file. Set to "replicate"
# and provide REPLICATE_API_TOKEN to hit api.replicate.com.
VIDEO_PROVIDER=stub
REPLICATE_API_TOKEN=
REPLICATE_MODEL=minimax/video-01
VIDEO_POLL_TIMEOUT_SECONDS=600

# Billing. "stub" lets the FE upgrade users instantly without an external call.
# "stripe" requires the next four vars + a webhook hitting POST /api/billing/webhook.
BILLING_PROVIDER=stub
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
BILLING_SUCCESS_URL=http://localhost:3000/account/billing?upgraded=1
BILLING_CANCEL_URL=http://localhost:3000/account/billing?canceled=1
