# Copy to .env and adjust. Names match docs/foundation/architecture.md.

ENV=dev
API_ORIGIN=http://localhost:8000
WEB_ORIGIN=http://localhost:3000

AUTH_SECRET=change-me-32-bytes-or-more
AUTH_TOKEN_TTL_SECONDS=28800

# Dev: SQLite. Real: postgresql+asyncpg://flova:flova@localhost:5432/flova
DATABASE_URL=sqlite+aiosqlite:///./flova.db

REDIS_URL=redis://localhost:6379/0

STORAGE_BACKEND=local
STORAGE_LOCAL_ROOT=./storage

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

PIKPAK_USERNAME=
PIKPAK_PASSWORD=

GPU_BURST_API_KEY=
GPU_BURST_ENDPOINT=
