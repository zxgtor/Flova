# Copy to .env (repo root). Used by docker compose.
# Anything left blank uses the default in docker-compose.yml.

ENV=dev

# Database (the compose stack runs its own Postgres)
POSTGRES_USER=flova
POSTGRES_PASSWORD=flova
POSTGRES_DB=flova

# Auth
AUTH_SECRET=dev-secret-change-me

# Public URLs (for CORS + billing redirects)
WEB_ORIGIN=http://localhost:3000
API_ORIGIN=http://localhost:8000
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Storage: local | r2
STORAGE_BACKEND=local
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# Video: stub | replicate
VIDEO_PROVIDER=stub
REPLICATE_API_TOKEN=
REPLICATE_MODEL=minimax/video-01

# Billing: stub | stripe
BILLING_PROVIDER=stub
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
BILLING_SUCCESS_URL=http://localhost:3000/account/billing?upgraded=1
BILLING_CANCEL_URL=http://localhost:3000/account/billing?canceled=1
